# Copie este arquivo para ".env" (na raiz) e preencha as chaves dos provedores que quiser usar.
# O .env NÃO vai para o git (.gitignore). Reinicie o servidor após criar/editar.
# Cada provedor é opcional — o editor mostra só os que têm chave. O resto do app funciona sem nenhuma.

# Claude (Anthropic) — console.anthropic.com
ANTHROPIC_API_KEY=

# ChatGPT (OpenAI) — platform.openai.com
OPENAI_API_KEY=

# Gemini (Google) — aistudio.google.com/apikey (geralmente começa com "AIza...")
GEMINI_API_KEY=

# Opcional: trocar o modelo de cada provedor.
# ANTHROPIC_MODEL=claude-opus-4-8     (ou claude-haiku-4-5 p/ baratear)
# OPENAI_MODEL=gpt-5.4-mini
# GEMINI_MODEL=gemini-2.5-flash

# Senha do PROFESSOR — protege os quizzes, gabaritos, estatísticas e o PDF dos alunos.
# Padrão (se vazio): "professor". TROQUE para uma senha sua, senão os alunos podem entrar.
# PROFESSOR_PASSWORD=

# Segredo do servidor para o token de login (impede forjar o token offline). É gerado e
# salvo sozinho em server/data/.prof-secret — só preencha se quiser fixá-lo (ex.: vários servidores).
# PROF_SECRET=

# Endereço público (IP ou hostname, SEM porta) usado no QR code de entrada dos alunos.
# Em geral é detectado sozinho. No Docker o contêiner não enxerga o IP da rede — então
# defina aqui o IP do PC do servidor (ex.: 192.168.0.2) para o QR apontar certo.
# PUBLIC_HOST=
